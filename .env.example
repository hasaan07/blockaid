# ===========================================
# BlockAid Environment Variables (template)
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
# ===========================================

# ----- MongoDB -----
MONGODB_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/blockaid?retryWrites=true&w=majority

# ----- Auth -----
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ----- Blockchain -----
# Polygon Amoy public RPC (or your own from Alchemy/Infura for higher rate limits)
NEXT_PUBLIC_AMOY_RPC=https://rpc-amoy.polygon.technology
NEXT_PUBLIC_CHAIN_ID=80002

# Filled in after running `npx hardhat run scripts/deploy.ts --network amoy` in Phase 2
NEXT_PUBLIC_FACTORY_ADDRESS=

# Used by Hardhat for deployments — DO NOT use a wallet with real funds
DEPLOYER_PRIVATE_KEY=

# ----- Pinata (IPFS pinning) -----
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
