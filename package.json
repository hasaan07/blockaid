{
  "name": "blockaid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:contracts": "hardhat test",
    "test:e2e": "playwright test",
    "test:all": "npm run test:contracts && npm run test && npm run test:e2e",
    "compile": "hardhat compile",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network amoy"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "bcryptjs": "^3.0.3",
    "ethers": "^6.16.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.3",
    "next": "14.2.35",
    "pinata": "^2.5.6",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.13",
    "@nomicfoundation/hardhat-ignition": "^3.1.7",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.7",
    "@nomicfoundation/hardhat-verify": "^3.0.19",
    "@playwright/test": "^1.60.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "chai": "^6.2.2",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.8.0",
    "jest": "^30.4.2",
    "mocha": "^11.7.6",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3"
  },
  "type": "module"
}
